# scape BotSdk endpoint
SCAPE_URL=ws://localhost:43595
BOT_SDK_TOKEN=dev-secret

# OpenClaw gateway endpoint
GATEWAY_URL=ws://localhost:18789
GATEWAY_TOKEN=replace-with-output-of: openclaw config get gateway.auth.token

# Default password for spawned agent accounts (>= 8 chars, scrypt-verified)
AGENT_DEFAULT_PASSWORD=agentscape

# Tunables
IDLE_MS=15000
SUBAGENT_TTL_MS=600000
